NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
GOOGLE_API_KEY=your-google-ai-api-key

# Backend API URL (Railway). Set this on Vercel when backend runs separately.
# Leave empty for local development (same-origin Next.js API routes).
NEXT_PUBLIC_API_URL=

# Frontend URL (set this on Railway backend for CORS).
# Supports multiple origins separated by comma. No trailing slashes.
# Example: FRONTEND_URL=https://www.snabchat.app,https://snab-chat.vercel.app
FRONTEND_URL=https://your-app.vercel.app

# Admin codes (JSON array). Move real values here instead of hardcoding in source code.
# Format: [{"code":"MY-ADMIN","name":"Full Name","number":1,"isDocAdmin":true}, ...]
ADMIN_CODES_JSON='[{"code":"ADMIN-1","name":"Admin Name","number":1,"isDocAdmin":true}]'
